# Francisco Holdings Inc. - Empire Backend Configuration
# The Trillion Dollar Skyscraper

# Server
PORT=3000
NODE_ENV=production

# Security
JWT_SECRET=your-ultra-secure-jwt-secret-here-min-256-bits
JWT_EXPIRE=7d
BCRYPT_ROUNDS=12

# CORS - Add all 45+ company domains
CORS_ORIGINS=https://franciscoholdingsinc.com,https://zprimedoxaihq.com,https://omniaguard.com,https://primedoxai.com,https://ccldr.net,https://vaultvelocityauto.com,https://kiaros.com,https://vigilax.com,https://cleanswarm.com,https://techpetcage.com

# WebSocket
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=10000

# Database (PostgreSQL recommended for production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=francisco_holdings
DB_USER=empire_admin
DB_PASSWORD=secure-password-here

# Redis (for real-time caching)
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# Empire Settings
TOTAL_FLOORS=392
ACTIVE_FLOORS=12
TOTAL_AGENTS=12847
GEMMA_VERSION=31B

# PayPal (verify these charge CUSTOMER not Derek)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live

# Cloudflare
CF_ZONE_ID=
CF_API_TOKEN=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
