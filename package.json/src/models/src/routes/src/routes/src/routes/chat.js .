const express = require('express');
const { v4: uuidv4 } = require('uuid');
const { run, get, all } = require('../models/database');

const router = express.Router();

// Start new chat session
router.post('/session', async (req, res) => {
  try {
    const { userId, floor, agentType = 'primeDox' } = req.body;
    const sessionId = uuidv4();

    await run(
      'INSERT INTO chat_sessions (session_id, user_id, floor, agent_type) VALUES (?, ?, ?, ?)',
      [sessionId, userId || null, floor || null, agentType]
    );

    res.status(201).json({
      message: 'Chat session started',
      sessionId,
      agent: agentType,
      floor: floor || 'lobby'
    });

  } catch (err) {
    console.error('Chat session error:', err);
    res.status(500).json({ error: 'Failed to start chat' });
  }
});

// Send message (placeholder for AI integration)
router.post('/message', async (req, res) => {
  try {
    const { sessionId, message, floor } = req.body;

    if (!sessionId || !message) {
      return res.status(400).json({ error: 'Session ID and message required' });
    }

    // TODO: Integrate with PrimeDox AI, OpenAI, Claude, or Gemini
    // For now, echo back with routing info
    const response = {
      reply: `PrimeDox AI received: "${message}"`,
      routedTo: floor ? `Floor ${floor} specialist` : 'General concierge',
      timestamp: new Date().toISOString(),
      nextStep: 'Connect to agent swarm backend'
    };

    res.json(response);

  } catch (err) {
    console.error('Chat message error:', err);
    res.status(500).json({ error: 'Failed to process message' });
  }
});

// Get session history
router.get('/session/:sessionId', async (req, res) => {
  try {
    const session = await get('SELECT * FROM chat_sessions WHERE session_id = ?', [req.params.sessionId]);
    if (!session) {
      return res.status(404).json({ error: 'Session not found' });
    }
    res.json({ session });
  } catch (err) {
    res.status(500).json({ error: 'Failed to fetch session' });
  }
});

// Get all active sessions
router.get('/sessions', async (req, res) => {
  try {
    const sessions = await all('SELECT * FROM chat_sessions ORDER BY created_at DESC');
    res.json({ sessions, count: sessions.length });
  } catch (err) {
    res.status(500).json({ error: 'Failed to fetch sessions' });
  }
});

module.exports = router;
