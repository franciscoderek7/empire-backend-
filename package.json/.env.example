# ============================================
# Empire Backend Environment Configuration
# Francisco Holdings Inc.
# Copy this file to .env and fill in real values
# NEVER commit .env to GitHub — it contains secrets
# ============================================

# Server Configuration
NODE_ENV=development
PORT=3000

# CORS — Allowed frontend domains
# Production: comma-separated list of your empire domains
CORS_ORIGIN=http://localhost:3000,https://franciscoholdingsinc.com,https://zprimedoxaihq.com

# JWT Authentication
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Database
# SQLite file path (relative to project root)
DATABASE_URL=./empire-database.sqlite

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# API Keys (Add as needed for AI integrations)
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-your-anthropic-key
# GEMINI_API_KEY=your-gemini-key

# Email / SMTP (for lead notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# PayPal Integration
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-secret
# PAYPAL_MODE=sandbox

# Logging
LOG_LEVEL=info
